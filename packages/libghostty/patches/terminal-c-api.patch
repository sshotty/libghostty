+/// Mode bitmask bits for `get_modes`.
+pub const mode_cursor_keys: u32 = 1 << 0;
+pub const mode_keypad_application: u32 = 1 << 1;
+pub const mode_auto_wrap: u32 = 1 << 2;
+pub const mode_origin: u32 = 1 << 3;
+pub const mode_insert: u32 = 1 << 4;
+pub const mode_bracketed_paste: u32 = 1 << 5;
+pub const mode_mouse_x10: u32 = 1 << 6;
+pub const mode_mouse_normal: u32 = 1 << 7;
+pub const mode_mouse_button_event: u32 = 1 << 8;
+pub const mode_mouse_any_event: u32 = 1 << 9;
+pub const mode_alternate_screen: u32 = 1 << 10;
+pub const mode_mouse_alt_scroll: u32 = 1 << 11;
+
+pub fn get_modes(handle: Handle) callconv(.c) u32 {
+    const wrapper = handle orelse return 0;
+    const t = &wrapper.terminal;
+    var result: u32 = 0;
+    if (t.modes.get(.cursor_keys)) result |= mode_cursor_keys;
+    if (t.modes.get(.keypad_keys)) result |= mode_keypad_application;
+    if (t.modes.get(.wraparound)) result |= mode_auto_wrap;
+    if (t.modes.get(.origin)) result |= mode_origin;
+    if (t.modes.get(.insert)) result |= mode_insert;
+    if (t.modes.get(.bracketed_paste)) result |= mode_bracketed_paste;
+    if (t.modes.get(.mouse_event_x10)) result |= mode_mouse_x10;
+    if (t.modes.get(.mouse_event_normal)) result |= mode_mouse_normal;
+    if (t.modes.get(.mouse_event_button)) result |= mode_mouse_button_event;
+    if (t.modes.get(.mouse_event_any)) result |= mode_mouse_any_event;
+    if (t.screens.active_key == .alternate) result |= mode_alternate_screen;
+    if (t.modes.get(.mouse_alternate_scroll)) result |= mode_mouse_alt_scroll;
+    return result;
+}
