+pub fn get_hyperlink(
+    handle: Handle,
+    row: c_int,
+    col: c_int,
+    out: [*]u8,
+    out_size: c_int,
+) callconv(.c) c_int {
+    if (row < 0 or col < 0 or out_size <= 0) return 0;
+    const wrapper = handle orelse return 0;
+    const rs = &wrapper.render_state;
+    const urow: usize = @intCast(row);
+    const ucol: usize = @intCast(col);
+    if (urow >= rs.rows or ucol >= rs.cols) return 0;
+
+    const cells = rs.row_data.items(.cells)[urow];
+    if (cells.len == 0) return 0;
+
+    const raw = cells.items(.raw)[ucol];
+    if (!raw.hyperlink) return 0;
+
+    const pin = rs.row_data.items(.pin)[urow];
+    const p: *page.Page = &pin.node.data;
+    const rac = pin.rowAndCell();
+    const page_cells = p.getCells(rac.row);
+    const cell = &page_cells[ucol];
+
+    const hyperlink_id = p.lookupHyperlink(cell) orelse return 0;
+    const entry = p.hyperlink_set.get(p.memory, hyperlink_id);
+    const uri = entry.uri.slice(p.memory);
+
+    const count = @min(uri.len, @as(usize, @intCast(out_size)));
+    @memcpy(out[0..count], uri[0..count]);
+    return @intCast(count);
+}
