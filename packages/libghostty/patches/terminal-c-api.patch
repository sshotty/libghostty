+pub fn update(handle: Handle) callconv(.c) u8 {
+    const wrapper = handle orelse return 0;
+    wrapper.render_state.update(wrapper.alloc, &wrapper.terminal) catch return 0;
+    return switch (wrapper.render_state.dirty) {
+        .false => 0,
+        .partial => 1,
+        .full => 2,
+    };
+}
