new file mode 100644
index 000000000..3ba03a7aa
--- /dev/null
+++ b/src/terminal/c/terminal.zig
@@ -0,0 +1,1340 @@
+const std = @import("std");
+const Allocator = std.mem.Allocator;
+const lib_alloc = @import("../../lib/allocator.zig");
+const CAllocator = lib_alloc.Allocator;
+const Result = @import("result.zig").Result;
+const terminal_pkg = @import("../main.zig");
+const Terminal = terminal_pkg.Terminal;
+const RenderState = terminal_pkg.RenderState;
+const page = terminal_pkg.page;
+const stream_pkg = @import("../stream.zig");
+const stream_readonly = @import("../stream_readonly.zig");
+const size = @import("../size.zig");
+const Style = @import("../style.zig").Style;
+const modes = terminal_pkg.modes;
+const ansi = @import("../ansi.zig");
+
+const mouse_shape_pkg = @import("../mouse_shape.zig");
+
+const log = std.log.scoped(.terminal_c);
+
+/// Event flags returned by `write`. These mirror the role of
+/// `surfaceMessageWriter` calls in Ghostty's `StreamHandler`:
+/// the handler sets flags inline during parsing so the caller
+/// knows what changed without polling.
+pub const event_bell: u32 = 1 << 0;
+pub const event_title_changed: u32 = 1 << 1;
+pub const event_mouse_shape_changed: u32 = 1 << 2;
+pub const event_repaint: u32 = 1 << 3;
+pub const event_mode_changed: u32 = 1 << 4;
+pub const event_has_response: u32 = 1 << 5;
+
+/// C: GhosttyCell
+pub const GhosttyCell = extern struct {
+    codepoint: u32,
+    fg_r: u8,
+    fg_g: u8,
+    fg_b: u8,
+    bg_r: u8,
+    bg_g: u8,
+    bg_b: u8,
+    flags: u8,
+    wide: u8,
+    underline_style: u8,
+    grapheme_len: u8,
+    ul_r: u8 = 0,
+    ul_g: u8 = 0,
+    ul_b: u8 = 0,
+    ul_set: u8 = 0,
+    content_tag: u8 = 0,
+    semantic_content: u8 = 0,
+    has_hyperlink: u8 = 0,
+
+    pub const flag_bold: u8 = 1 << 0;
+    pub const flag_italic: u8 = 1 << 1;
+    pub const flag_strikethrough: u8 = 1 << 2;
+    pub const flag_inverse: u8 = 1 << 3;
+    pub const flag_invisible: u8 = 1 << 4;
+    pub const flag_blink: u8 = 1 << 5;
+    pub const flag_faint: u8 = 1 << 6;
+    pub const flag_overline: u8 = 1 << 7;
+};
+
+/// C: GhosttyTerminalConfig
+pub const GhosttyTerminalConfig = extern struct {
+    scrollback_limit: u32,
+    fg_r: u8,
+    fg_g: u8,
+    fg_b: u8,
+    fg_set: u8,
+    bg_r: u8,
+    bg_g: u8,
+    bg_b: u8,
+    bg_set: u8,
+    cursor_r: u8,
+    cursor_g: u8,
+    cursor_b: u8,
+    cursor_set: u8,
+    palette: [16]u32,
+    palette_set: u16,
+};
+
+const TerminalWrapper = struct {
+    alloc: Allocator,
+    terminal: Terminal,
+    stream: EventStream,
+    render_state: RenderState,
+    pending_events: u32 = 0,
+    last_mouse_shape: mouse_shape_pkg.MouseShape = .text,
+    bell_count: u32 = 0,
+    title_changed: bool = false,
+    title_buf: std.ArrayListUnmanaged(u8),
+    response_buf: std.ArrayListUnmanaged(u8),
+};
+
+/// C: GhosttyTerminal
+pub const Handle = ?*TerminalWrapper;
+
+const EventHandler = struct {
+    readonly: stream_readonly.Handler,
+    wrapper: *TerminalWrapper,
+
+    pub fn init(terminal: *Terminal, wrapper: *TerminalWrapper) EventHandler {
+        return .{
+            .readonly = stream_readonly.Handler.init(terminal),
+            .wrapper = wrapper,
+        };
+    }
+
+    pub fn deinit(self: *EventHandler) void {
+        self.readonly.deinit();
+    }
+
+    pub fn vt(
+        self: *EventHandler,
+        comptime action: stream_pkg.Action.Tag,
+        value: stream_pkg.Action.Value(action),
+    ) !void {
+        switch (action) {
+            .bell => {
+                self.wrapper.bell_count +|= 1;
+                self.wrapper.pending_events |= event_bell;
+            },
+            .window_title => {
+                self.wrapper.title_buf.clearRetainingCapacity();
+                self.wrapper.title_buf.appendSlice(self.wrapper.alloc, value.title) catch {};
+                self.wrapper.title_changed = true;
+                self.wrapper.pending_events |= event_title_changed;
+            },
+            .set_mode, .reset_mode => {
+                try self.readonly.vt(action, value);
+                self.wrapper.pending_events |= event_repaint | event_mode_changed;
+            },
+            .device_attributes => self.deviceAttributes(value),
+            .device_status => self.deviceStatusReport(value),
+            .enquiry => self.appendResponse("\x1b[?1;0c"),
+            .request_mode => self.requestMode(value.mode),
+            .request_mode_unknown => self.requestModeUnknown(value),
+            .kitty_keyboard_query => self.kittyKeyboardQuery(),
+            .xtversion => self.appendResponse("\x1bP>|ghostty-vt\x1b\\"),
+            else => {
+                try self.readonly.vt(action, value);
+                self.wrapper.pending_events |= event_repaint;
+                if (self.wrapper.terminal.mouse_shape != self.wrapper.last_mouse_shape) {
+                    self.wrapper.last_mouse_shape = self.wrapper.terminal.mouse_shape;
+                    self.wrapper.pending_events |= event_mouse_shape_changed;
+                }
+            },
+        }
+    }
+
+    fn deviceAttributes(self: *EventHandler, req: ansi.DeviceAttributeReq) void {
+        switch (req) {
+            .primary => self.appendResponse("\x1b[?62;22c"),
+            .secondary => self.appendResponse("\x1b[>1;10;0c"),
+            else => {},
+        }
+    }
+
+    fn deviceStatusReport(self: *EventHandler, value: stream_pkg.Action.Value(.device_status)) void {
+        switch (value.request) {
+            .operating_status => self.appendResponse("\x1b[0n"),
+            .cursor_position => {
+                const t = &self.wrapper.terminal;
+                const pos: struct { x: usize, y: usize } = if (t.modes.get(.origin)) .{
+                    .x = t.screens.active.cursor.x -| t.scrolling_region.left,
+                    .y = t.screens.active.cursor.y -| t.scrolling_region.top,
+                } else .{
+                    .x = t.screens.active.cursor.x,
+                    .y = t.screens.active.cursor.y,
+                };
+                var buf: [32]u8 = undefined;
+                const resp = std.fmt.bufPrint(&buf, "\x1b[{};{}R", .{
+                    pos.y + 1,
+                    pos.x + 1,
+                }) catch return;
+                self.appendResponse(resp);
+            },
+            else => {},
+        }
+    }
+
+    fn requestMode(self: *EventHandler, mode: terminal_pkg.modes.Mode) void {
+        const tag: modes.ModeTag = @bitCast(@intFromEnum(mode));
+        const code: u8 = if (self.wrapper.terminal.modes.get(mode)) 1 else 2;
+        var buf: [32]u8 = undefined;
+        const resp = std.fmt.bufPrint(&buf, "\x1b[{s}{};{}$y", .{
+            if (tag.ansi) "" else "?",
+            tag.value,
+            code,
+        }) catch return;
+        self.appendResponse(resp);
+    }
+
+    fn requestModeUnknown(self: *EventHandler, raw: stream_pkg.Action.Value(.request_mode_unknown)) void {
+        var buf: [32]u8 = undefined;
+        const resp = std.fmt.bufPrint(&buf, "\x1b[{s}{};0$y", .{
+            if (raw.ansi) "" else "?",
+            raw.mode,
+        }) catch return;
+        self.appendResponse(resp);
+    }
+
+    fn kittyKeyboardQuery(self: *EventHandler) void {
+        var buf: [16]u8 = undefined;
+        const resp = std.fmt.bufPrint(&buf, "\x1b[?{}u", .{
+            self.wrapper.terminal.screens.active.kitty_keyboard.current().int(),
+        }) catch return;
+        self.appendResponse(resp);
+    }
+
+    fn appendResponse(self: *EventHandler, data: []const u8) void {
+        self.wrapper.response_buf.appendSlice(self.wrapper.alloc, data) catch return;
+        self.wrapper.pending_events |= event_has_response;
+    }
+};
+
+const EventStream = stream_pkg.Stream(EventHandler);
+
+pub fn new(
+    alloc_: ?*const CAllocator,
+    cols: c_int,
+    rows: c_int,
+    result: *Handle,
+) callconv(.c) Result {
+    return new_with_config(alloc_, cols, rows, null, result);
+}
+
+pub fn new_with_config(
+    alloc_: ?*const CAllocator,
+    cols: c_int,
+    rows: c_int,
+    config: ?*const GhosttyTerminalConfig,
+    result: *Handle,
+) callconv(.c) Result {
+    const alloc = lib_alloc.default(alloc_);
+
+    const ucols: size.CellCountInt = if (cols > 0) @intCast(cols) else 80;
+    const urows: size.CellCountInt = if (rows > 0) @intCast(rows) else 24;
+
+    var terminal_colors: Terminal.Colors = .default;
+    var scrollback: u32 = 10000;
+    if (config) |cfg| {
+        scrollback = cfg.scrollback_limit;
+        if (cfg.fg_set != 0) terminal_colors.foreground = .init(.{
+            .r = cfg.fg_r,
+            .g = cfg.fg_g,
+            .b = cfg.fg_b,
+        });
+        if (cfg.bg_set != 0) terminal_colors.background = .init(.{
+            .r = cfg.bg_r,
+            .g = cfg.bg_g,
+            .b = cfg.bg_b,
+        });
+        if (cfg.cursor_set != 0) terminal_colors.cursor = .init(.{
+            .r = cfg.cursor_r,
+            .g = cfg.cursor_g,
+            .b = cfg.cursor_b,
+        });
+        for (0..16) |i| {
+            if (cfg.palette_set & (@as(u16, 1) << @intCast(i)) != 0) {
+                const rgb = cfg.palette[i];
+                terminal_colors.palette.set(@intCast(i), .{
+                    .r = @intCast((rgb >> 16) & 0xFF),
+                    .g = @intCast((rgb >> 8) & 0xFF),
+                    .b = @intCast(rgb & 0xFF),
+                });
+            }
+        }
+    }
+
+    var t = Terminal.init(alloc, .{
+        .cols = ucols,
+        .rows = urows,
+        .max_scrollback = scrollback,
+        .colors = terminal_colors,
+    }) catch return .out_of_memory;
+    errdefer t.deinit(alloc);
+
+    const wrapper = alloc.create(TerminalWrapper) catch return .out_of_memory;
+    wrapper.* = .{
+        .alloc = alloc,
+        .terminal = t,
+        .stream = undefined,
+        .render_state = .empty,
+        .title_buf = .empty,
+        .response_buf = .empty,
+    };
+
+    wrapper.stream = .initAlloc(alloc, .init(&wrapper.terminal, wrapper));
+
+    result.* = wrapper;
+    return .success;
+}
+
+pub fn free(handle: Handle) callconv(.c) void {
+    const wrapper = handle orelse return;
+    const alloc = wrapper.alloc;
+    wrapper.stream.deinit();
+    wrapper.render_state.deinit(alloc);
+    wrapper.terminal.deinit(alloc);
+    wrapper.title_buf.deinit(alloc);
+    wrapper.response_buf.deinit(alloc);
+    alloc.destroy(wrapper);
+}
+
+pub fn write(
+    handle: Handle,
+    data: [*]const u8,
+    len: usize,
+) callconv(.c) u32 {
+    const wrapper = handle orelse return 0;
+    wrapper.pending_events = 0;
+    wrapper.stream.nextSlice(data[0..len]) catch |err| {
+        log.warn("write error: {}", .{err});
+    };
+    return wrapper.pending_events;
+}
+
+pub fn resize(
+    handle: Handle,
+    cols: c_int,
+    rows: c_int,
+) callconv(.c) Result {
+    const wrapper = handle orelse return .invalid_value;
+    const ucols: size.CellCountInt = if (cols > 0) @intCast(cols) else 1;
+    const urows: size.CellCountInt = if (rows > 0) @intCast(rows) else 1;
+    wrapper.terminal.resize(wrapper.alloc, ucols, urows) catch return .out_of_memory;
+    return .success;
+}
+
+pub fn has_response(handle: Handle) callconv(.c) bool {
+    const wrapper = handle orelse return false;
+    return wrapper.response_buf.items.len > 0;
+}
+
+pub fn read_response(
+    handle: Handle,
+    out: [*]u8,
+    out_size: c_int,
+) callconv(.c) c_int {
+    const wrapper = handle orelse return 0;
+    const resp = wrapper.response_buf.items;
+    if (resp.len == 0) return 0;
+    const count = @min(resp.len, @as(usize, @intCast(out_size)));
+    @memcpy(out[0..count], resp[0..count]);
+    if (count == resp.len) {
+        wrapper.response_buf.clearRetainingCapacity();
+    } else {
+        const remaining = resp.len - count;
+        std.mem.copyForwards(u8, wrapper.response_buf.items[0..remaining], resp[count..]);
+        wrapper.response_buf.items.len = remaining;
+    }
+    return @intCast(count);
+}
