+
+    // First 5 cells ("Click") should have hyperlink set
+    try testing.expectEqual(@as(u8, 1), buf[0].has_hyperlink);
+    try testing.expectEqual(@as(u32, 'C'), buf[0].codepoint);
+    try testing.expectEqual(@as(u8, 1), buf[4].has_hyperlink);
+
+    // Cell after the link text should not have hyperlink
+    try testing.expectEqual(@as(u8, 0), buf[5].has_hyperlink);
+
+    // Query the URI for cell (0, 0)
+    var uri_buf: [256]u8 = undefined;
+    const uri_len = get_hyperlink(h, 0, 0, &uri_buf, 256);
+    try testing.expect(uri_len > 0);
+    try testing.expectEqualStrings("https://example.com", uri_buf[0..@intCast(uri_len)]);
+
+    // Cell without hyperlink returns 0
+    const no_link = get_hyperlink(h, 0, 5, &uri_buf, 256);
+    try testing.expectEqual(@as(c_int, 0), no_link);
+}
